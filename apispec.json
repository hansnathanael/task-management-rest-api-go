{
    "openapi": "3.0.3",
    "info": {
        "title": "Task Management RESTful API",
        "description": "API Spec for Task Management RESTful API",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8080"
        }
    ],
    "paths": {
        "/tasks": {
            "get": {
                "security": [{
                    "TaskAuth": []
                }],
                "tags": ["Task Management API"],
                "description": "List All Tasks",
                "summary": "List All Tasks",
                "responses": {
                    "200": {
                        "description": "Successfully get all tasks",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "code": {
                                            "type": "number"
                                        },
                                        "status": {
                                            "type": "string"
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/Task"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "security": [{
                    "TaskAuth": []
                }],
                "tags": ["Task Management API"],
                "summary": "Create New Task",
                "description": "Create New Task",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/CreateOrUpdateTask"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Successfully created Task",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "code": {
                                            "type": "number"
                                        },
                                        "status": {
                                            "type": "string"
                                        },
                                        "data": {
                                            "$ref": "#/components/schemas/Task"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/tasks/{taskId}": {
            "get": {
                "security": [{
                    "TaskAuth": []
                }],
                "tags": ["Task Management API"],
                "summary": "Get Task By Id",
                "description": "Get Task By Id",
                "parameters": [
                    {
                        "name": "taskId",
                        "in": "path",
                        "description": "Task Id"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successfully get task by id",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "code": {
                                            "type": "number"
                                        },
                                        "status": {
                                            "type": "string"
                                        },
                                        "data": {
                                            "$ref": "#/components/schemas/Task"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "put": {
                "security": [{
                    "TaskAuth": []
                }],
                "tags": ["Task Management API"],
                "summary": "Update Task By Id",
                "description": "Update Task By Id",
                "parameters": [
                    {
                        "name": "taskId",
                        "in": "path",
                        "description": "Task Id"
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/CreateOrUpdateTask"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Successfully updated task by id",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "code": {
                                            "type": "number"
                                        },
                                        "status": {
                                            "type": "string"
                                        },
                                        "data": {
                                            "$ref": "#/components/schemas/Task"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "delete": {
                "security": [{
                    "TaskAuth": []
                }],
                "tags": ["Task Management API"],
                "summary": "Delete Task By Id",
                "description": "Delete Task By Id",
                "parameters": [
                    {
                        "name": "taskId",
                        "in": "path",
                        "description": "Task Id"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successfully deleted task by id",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "code": {
                                            "type": "number"
                                        },
                                        "status": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "Task": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "number"
                    },
                    "title": {
                        "type": "string"
                    },
                    "description": {
                        "type": "string"
                    },
                    "status": {
                        "type": "string"
                    }
                }
            },
            "CreateOrUpdateTask": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    }
                }
            }
        },
        "securitySchemes": {
            "TaskAuth": {
                "type": "apiKey",
                "in": "header",
                "name": "X-API-Key",
                "description": "Authentication For Task API"
            }
        }
    }
}